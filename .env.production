# ==============================================
# 本番環境設定（compose.production.yaml想定）
# VPS上でDocker Composeを使用する場合の設定
# ==============================================

# Ruby version
RUBY_VERSION=3.4.8

# Rails version
RAILS_VERSION=8.1.2

# Node.js version
NODE_VERSION=24

# PostgreSQL version
POSTGRES_VERSION=17-bookworm

# ==============================================
# Database configuration (本番環境用)
# compose.production.yamlのpostgresdbサービスに接続
# ==============================================
POSTGRES_HOST=postgresdb
POSTGRES_PORT=5432
POSTGRES_USER=postgres-user
POSTGRES_PASSWORD=postgres-password
POSTGRES_DB=okinawa_lodging_tax_production

# DATABASE_URL (Rails が自動的に使用)
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ==============================================
# Rails configuration (本番環境用)
# ==============================================
RAILS_ENV=production

# SECRET_KEY_BASE (必須：本番環境用シークレットキー)
# 生成方法: docker compose -f compose.production.yaml run --rm railsapp bundle exec rails secret
SECRET_KEY_BASE=change-this-to-generated-secret-key-base

# ログ設定
RAILS_LOG_TO_STDOUT=true
RAILS_LOG_LEVEL=info

# 静的ファイル配信（CDNを使わない場合はtrue）
RAILS_SERVE_STATIC_FILES=true

# Puma設定
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2

# ==============================================
# Square configuration (本番環境用)
# https://developer.squareup.com/apps
# ==============================================
# SQUARE_ACCESS_TOKEN=your_square_access_token_here
# SQUARE_APPLICATION_ID=your_square_application_id_here
# SQUARE_LOCATION_ID=your_square_location_id_here
# SQUARE_ENVIRONMENT=production
