# ==============================================
# プロジェクト設定
# 以下の値を編集してください
# ==============================================

# Ruby version (編集可能)
RUBY_VERSION=3.4.8

# Rails version (編集可能)
RAILS_VERSION=8.1.2

# Node.js version (編集可能)
NODE_VERSION=24

# PostgreSQL version (編集可能)
POSTGRES_VERSION=17-bookworm

# ==============================================
# Database configuration (編集可能)
# ==============================================
POSTGRES_HOST=postgresdb
POSTGRES_PORT=5432
POSTGRES_USER=postgres-user
POSTGRES_PASSWORD=postgres-password
POSTGRES_DB=okinawa_lodging_tax_development

# DATABASE_URL (Rails が自動的に使用)
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ==============================================
# Square configuration (編集可能)
# Square Developer Dashboardから取得したキーを設定してください
# https://developer.squareup.com/apps
# ==============================================
SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_APPLICATION_ID=your_square_application_id_here
SQUARE_LOCATION_ID=your_square_location_id_here
SQUARE_ENVIRONMENT=sandbox

# ==============================================
# Sales CRM configuration
# ==============================================
SALES_CRM_DB=sales_crm_development
